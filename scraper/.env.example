# =============================================================================
# Copy this file to .env and fill in your API credentials:
#   cp .env.example .env
# =============================================================================

# --- Kalshi API ---
# Auth uses RSA key signing. Generate a keypair, upload the public key
# at https://kalshi.com/account/api, and note the Key ID.
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_RSA_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Use "prod" for real markets, "demo" for sandbox/paper trading
KALSHI_ENV=demo

# --- API-Tennis (api-tennis.com) ---
# Sign up at https://api-tennis.com/ to get your API key.
# Key is passed as a query parameter on each request.
API_TENNIS_KEY=your-api-tennis-key-here
